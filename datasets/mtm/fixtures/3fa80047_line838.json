      "annotations": []
    },
    {
      "_id": "15",
      "role": "volunteer",
      "content": "Actually, <PERSON> can be divided by x, so the answer will be slightly different",
      "start_time": "",
      "end_time": "",
      "timestamp": "",
      "session_id": "",
      "sequence_id": "15",
      "annotations": []
    },
    {
      "_id": "16",
      "role": "volunteer",
      "content": "x^2 is the same thing as x times x",
      "start_time": "",
      "end_time": "",
      "timestamp": "",
      "session_id": "",
      "sequence_id": "16",
      "annotations": []
    },
    {
      "_id": "17",
      "role": "volunteer",
      "content": "So if we divide out x, then we're left with another x",
