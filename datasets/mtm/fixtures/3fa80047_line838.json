      "annotations": []
    },
    {
      "_id": "11",
      "role": "volunteer",
      "content": "Yes!",
      "start_time": "",
      "end_time": "",
      "timestamp": "",
      "session_id": "",
      "sequence_id": "11",
      "annotations": []
    },
    {
      "_id": "12",
      "role": "volunteer",
      "content": "That means we can factor x out",
