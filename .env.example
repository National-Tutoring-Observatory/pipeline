LLM_PROVIDER='AI_GATEWAY' # AI_GATEWAY, OPENAI based upon app/llmProviders
# AI_GATEWAY_KEY=''
# AI_GATEWAY_BASE_URL=''
# AI_GATEWAY_PROVIDER='GEMINI' #   CHAT_GPT | GEMINI | CLAUDE based upon AI_GATEWAY_PROVIDERS in app/llmProviders/aiGatewayProviders.ts
# OPEN_AI_KEY=''
STORAGE_ADAPTER='LOCAL' # AWS_S3, LOCAL based upon app/storageAdapters
# AWS_BUCKET=''
# AWS_REGION=''
# AWS_KEY=''
# AWS_SECRET=''
DOCUMENTS_ADAPTER='LOCAL' # DOCUMENT_DB, LOCAL based upon app/documentAdapters
# DOCUMENT_DB_CONNECTION_STRING='' # AWS DocumentDB Connection String
# DOCUMENT_DB_USERNAME='' # AWS DocumentDB Username
# DOCUMENT_DB_PASSWORD='' # AWS DocumentDB Password
# DOCUMENT_DB_LOCAL='true' # Set to 'true' for local MongoDB (disables TLS), omit for remote/AWS DocumentDB
SESSION_SECRET='' # A long random string for session encryption `openssl rand -hex 64`
GITHUB_CLIENT_ID='' # Github OAuth App Client ID
GITHUB_CLIENT_SECRET=''# Github OAuth App Client Secret
SUPER_ADMIN_GITHUB_ID='' # Github ID to configure for super admin rights on application setup
AUTH_CALLBACK_URL='http://localhost:5173/auth/callback'
PROJECT_ROOT='' # Path to the project root directory, e.g. /home/user/pipeline
# REDIS_LOCAL='true' # Use local Redis (localhost:6379) running with `yarn redis`. Overrides REDIS_URL
# REDIS_URL='' # External Redis URL
BULLMQ_PRO_TOKEN='' # BullMQ Pro license token - add to ~/.npmrc: //npm.taskforce.sh/:_authToken=<token>
# PLAYWRIGHT_BROWSER_EXECUTABLE_PATH='' # Optional: Path to browser executable for Playwright tests. Examples:
  # macOS Brave: '/Applications/Brave Browser.app/Contents/MacOS/Brave Browser'
  # macOS Chrome: '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome'
  # Linux Chrome: '/usr/bin/google-chrome'
  # If omitted, uses default Chrome installation
# GOOGLE_ANALYTICS_ID='' # Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
# GOOGLE_ANALYTICS_API_SECRET='' # GA4 Measurement Protocol API Secret (for server-side event tracking)
# OTEL_ENABLED='true' # Enable OpenTelemetry instrumentation (traces + metrics)
# OTEL_SERVICE_NAME='sandpiper-app' # Service name in traces (use 'pipeline-workers' for workers)
# OTEL_EXPORTER_OTLP_ENDPOINT='http://localhost:4318' # OTLP collector HTTP endpoint
# OTEL_DEBUG='false' # Enable OpenTelemetry diagnostic logging
# OTEL_RESOURCE_ATTRIBUTES='deployment.environment=development' # Environment label: development, staging, production
